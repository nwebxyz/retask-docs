---
/**
 * Top navigation: Retask product links + an "Open app" CTA. All open in a new tab.
 * (The default social icons are intentionally not rendered here.)
 */
const navLinks = [
  { label: 'Home', href: 'https://retask.work/' },
  { label: 'Pricing', href: 'https://retask.work/pricing' },
];
---

<nav class="retask-topnav" aria-label="Retask">
  {
    navLinks.map((link) => (
      <a
        class="retask-topnav__link"
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
      >
        {link.label}
      </a>
    ))
  }
</nav>

<a
  class="retask-topnav__cta"
  href="https://app.retask.work"
  target="_blank"
  rel="noopener noreferrer">Open app</a
>
